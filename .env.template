# FarmGuardian AI - Environment Configurations Template
# Copy this file to '.env' and fill in your actual API keys.
# Do NOT check your actual '.env' file into Git.

# ---------------------------------------------------------
# Option A: Google AI Studio (Recommended for quick local tests)
# ---------------------------------------------------------
# Set this to False to bypass Vertex AI and use standard Google AI Studio Gemini API
GOOGLE_GENAI_USE_VERTEXAI=False

# Your Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ---------------------------------------------------------
# Option B: Vertex AI (Recommended for production/GCP environments)
# ---------------------------------------------------------
# Set this to True to use Vertex AI on Google Cloud Platform (requires GCP authentication)
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=YOUR_GCP_PROJECT_ID
# GOOGLE_CLOUD_LOCATION=us-central1

# ---------------------------------------------------------
# Third-Party Tools (Optional, app has fallbacks if not provided)
# ---------------------------------------------------------
# OpenWeatherMap API Key (for real-time weather forecasts)
# Get a free key at: https://openweathermap.org/
OPENWEATHERMAP_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE

# Tavily Search API Key (for government scheme and market price web searches)
# Get a key at: https://tavily.com/
TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE
